  FORMAT_TYPE = "C"
  MAXIMUM_SIZE = "30"

  ALPHANUMERIC_ALLOWED_FLAG = "Y"
  UPPERCASE_ONLY_FLAG = "N"
  NUMERIC_MODE_ENABLED_FLAG = "N"

  DESCRIPTION = "Dummy Value Set For AOM Migration Testing"

  BEGIN VSET_VALUE "" "TEST_VALUE"

    OWNER = "TESTUSER"
    LAST_UPDATE_DATE = "2026/07/14"

    ENABLED_FLAG = "Y"
    SUMMARY_FLAG = "N"
    START_DATE_ACTIVE = "2026/07/14"

    FLEX_VALUE_MEANING = "Test Value"
    DESCRIPTION = "Dummy Flex Value"

  END VSET_VALUE

END VALUE_SET