# -- Begin Entity Definitions --

DEFINE FORM
  KEY   APPLICATION_SHORT_NAME          VARCHAR2(4000)
  KEY   FORM_NAME                       VARCHAR2(4000)
  BASE  AUDIT_ENABLED_FLAG              VARCHAR2(1)
  BASE  LAST_UPDATE_DATE                VARCHAR2(10)
  TRANS USER_FORM_NAME                  VARCHAR2(80)
  TRANS DESCRIPTION                     VARCHAR2(240)
  CTX   OWNER                           VARCHAR2(4000)
END FORM

# -- End Entity Definitions --


BEGIN FORM "FND" "XX_TEST_FORM"
  AUDIT_ENABLED_FLAG = "N"
  LAST_UPDATE_DATE = "2026/07/13"
  USER_FORM_NAME = "XX Test Form"
  DESCRIPTION = "Dummy Form For Migration Testing"
  OWNER = "TESTUSER"
END FORM
